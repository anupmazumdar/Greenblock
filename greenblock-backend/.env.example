## ── Weather ──────────────────────────────────────────────────────────────────
WEATHER_API_KEY=
OWM_CITY=Jaipur

## ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins. Use '*' only for local/dev.
ALLOWED_ORIGINS=*

## ── Sensor Mode ──────────────────────────────────────────────────────────────
# "serial" = read from Arduino via USB  |  "gpio" = read RPi4 GPIO pins directly
SENSOR_MODE=serial
SERIAL_PORT=auto
BAUD_RATE=9600
BACKEND_URL=http://localhost:8000
RETRY_DELAY=5
POST_TIMEOUT=5
READ_INTERVAL=2.0
LOG_LEVEL=INFO

## ── RPi4 GPIO Pin Assignments (BCM numbering) ────────────────────────────────
GPIO_DHT_PIN=4
GPIO_PIR_PIN=17
GPIO_RELAY1_PIN=23
GPIO_RELAY2_PIN=24
CO2_UART_PORT=/dev/ttyS0

## ── Polygon Oracle ───────────────────────────────────────────────────────────
# Dedicated oracle wallet private key — NEVER reuse your deployer key.
# This address must be set as oracleSigner in CreditRegistry.sol on deployment.
ORACLE_PRIVATE_KEY=
ORACLE_ADDRESS=

## ── Algorand Oracle ──────────────────────────────────────────────────────────
# 25-word mnemonic of the oracle Algorand account.
# Generate: python -c "from algosdk import account,mnemonic; pk,addr=account.generate_account(); print(mnemonic.from_private_key(pk), addr)"
ALGORAND_ORACLE_MNEMONIC=
ALGORAND_ORACLE_ADDRESS=
ALGORAND_NODE_URL=https://testnet-api.algonode.cloud
ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud

## ── Solana Oracle ────────────────────────────────────────────────────────────
# Base58-encoded 64-byte secret key (seed + pub).
# Generate: solana-keygen new --outfile oracle-keypair.json  (then base58-encode)
SOLANA_ORACLE_SECRET_KEY=
SOLANA_ORACLE_ADDRESS=
SOLANA_RPC_URL=https://api.devnet.solana.com
