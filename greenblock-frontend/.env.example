# Frontend runtime API base.
# Can be origin OR origin/api. Both are supported.
# Examples:
# VITE_API_URL=http://192.168.1.25:8000
# VITE_API_URL=https://greenblock-production.up.railway.app
VITE_API_URL=

# Optional dev-only proxy target for Vite.
# If not set, Vite falls back to VITE_API_URL, then http://127.0.0.1:8000
# Example:
# VITE_BACKEND_PROXY_TARGET=http://192.168.1.25:8000
VITE_BACKEND_PROXY_TARGET=