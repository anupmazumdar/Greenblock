# ── Backend API ───────────────────────────────────────────────────────────────
# URL of your deployed FastAPI backend (Vercel / Railway project).
VITE_API_URL=https://greenblock-api.vercel.app

# Optional dev-only proxy target for Vite.
VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:8000

# WebSocket base URL for real-time RPi4 sensor data.
# If not set, derived automatically from VITE_API_URL.
# Example: wss://greenblock-api.railway.app
VITE_WS_URL=

# ── Polygon Amoy Testnet contracts ────────────────────────────────────────────
# Run: npx hardhat run scripts/deploy.js --network polygonAmoy
# Then copy addresses from greenblock-blockchain/deployments/polygonAmoy.json
VITE_CONTRACT_GREEN_TOKEN=
VITE_CONTRACT_CREDIT_REGISTRY=
VITE_CONTRACT_MARKETPLACE=
VITE_CONTRACT_RETIREMENT_LEDGER=

# ── Algorand TestNet contracts ────────────────────────────────────────────────
# Run: cd greenblock-blockchain/algorand && python deploy.py
# Then copy IDs from algorand_deployments/testnet.json
VITE_ALGORAND_CREDIT_REGISTRY_APP_ID=
VITE_ALGORAND_MARKETPLACE_APP_ID=
VITE_ALGORAND_RETIREMENT_LEDGER_APP_ID=
VITE_ALGORAND_GBT_ASSET_ID=
VITE_ALGORAND_NODE_URL=https://testnet-api.algonode.cloud
VITE_ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud

# ── Solana Devnet contracts ───────────────────────────────────────────────────
# Run: cd greenblock-blockchain/solana && anchor build && ts-node scripts/deploy.ts
# Then copy IDs from solana_deployments/devnet.json
VITE_SOLANA_CREDIT_REGISTRY_PROGRAM_ID=
VITE_SOLANA_GBT_MINT=
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
