# ── Backend API ───────────────────────────────────────────────────────────────
# URL of your deployed FastAPI backend (Vercel project for greenblock-backend).
# Example: https://greenblock-api.vercel.app
# Set this in Vercel dashboard → Project Settings → Environment Variables.
VITE_API_URL=https://greenblock-api.vercel.app

# Optional dev-only proxy target for Vite.
# If not set, Vite falls back to VITE_API_URL, then http://127.0.0.1:8000
VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:8000

# ── Blockchain Contracts (Polygon Amoy Testnet) ───────────────────────────────
# Copy addresses from greenblock-blockchain/deployments/polygonAmoy.json
# after running: npx hardhat run scripts/deploy.js --network polygonAmoy
VITE_CONTRACT_GREEN_TOKEN=
VITE_CONTRACT_CREDIT_REGISTRY=
VITE_CONTRACT_MARKETPLACE=
VITE_CONTRACT_RETIREMENT_LEDGER=
