[Unit]
Description=GreenBlock FastAPI Backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/home/pi/Greenblock/greenblock-backend
EnvironmentFile=/home/pi/Greenblock/greenblock-backend/.env
ExecStart=/home/pi/Greenblock/greenblock-backend/.venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
