# Deployer wallet private key (NEVER commit the real key)
DEPLOYER_PRIVATE_KEY=your_wallet_private_key_here

# Polygon RPC endpoints (get free ones from Alchemy / Infura / QuickNode)
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology
POLYGON_MAINNET_RPC=https://polygon-rpc.com

# Polygonscan API key for contract verification
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Oracle signer address (the FastAPI backend wallet address)
ORACLE_SIGNER_ADDRESS=0x0000000000000000000000000000000000000000
